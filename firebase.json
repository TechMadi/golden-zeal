{
  "hosting": {
    "public": "dist/golden-zeal/browser",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/crm/**",
        "destination": "/crm/index.html"
      },
      {
        "source": "/crm",
        "destination": "/crm/index.html"
      },
      {
        "source": "/**",
        "destination": "/index.html"
      }
    ]
  }
}
